---
// Minimal HUD footer (ported from code.html lines 448-451).
interface Props {
  name?: string
}
const { name = 'W.J. SMITH' } = Astro.props
const year = new Date().getFullYear()
---

<footer
  class="w-full py-8 text-center border-t border-outline-variant/10 font-label-code text-xs text-on-surface-variant tracking-widest uppercase bg-[#05070f] relative z-10"
>
  © {year} SYSTEMS_CORE // {name} // GLOBAL_REACH
</footer>
